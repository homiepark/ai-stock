{% extends "site_base.html.j2" %}
{% block title %}리포트 기록 — AI 투자{% endblock %}

{% block content %}
<section class="space-y-2">
  <h1 class="text-2xl font-bold text-white">📚 리포트 기록</h1>
  <p class="text-sm text-slate-400">{{ entries|length }}일치 기록 · 최신순</p>
</section>

<section>
  <ul class="bg-slate-900 border border-slate-800 rounded-lg divide-y divide-slate-800">
    {% for e in entries %}
    <li>
      <a href="./{{ e.filename }}" class="flex items-center justify-between px-4 py-3 hover:bg-slate-800/50">
        <span class="font-mono text-white">{{ e.date }}</span>
        <span class="text-xs text-slate-500">→</span>
      </a>
    </li>
    {% else %}
    <li class="px-4 py-6 text-center text-slate-500 text-sm">아직 기록이 없습니다.</li>
    {% endfor %}
  </ul>
</section>
{% endblock %}
